bool KeyencePlcSubSystemHelperPrivate::writeFloat(const std::string address, const float value)
{
	float buffValue = value;
	uint32_t uint_num = *(reinterpret_cast<uint32_t*>(&buffValue));
	bool res = false;
	std::string command = "WR";
	command.append(" ");
	command.append(address);
	command.append(".D");
	command.append(" ");
	command.append(std::to_string(uint_num));
	std::string recvData;
	if (sendAndReceiveMessage(command, recvData) && recvData == WRITE_SUCESS_RESPONSE_DATA)
	{
		res = true;
	}
	return res;
}
