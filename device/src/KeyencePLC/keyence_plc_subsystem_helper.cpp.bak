}

bool KeyencePlcSubSystemHelperPrivate::writeDouble(const std::string address, const double value)
{
	bool res = false;
	std::string command = "WRS";
	command.append(" ");
	command.append(address);
	command.append(".D");
	command.append(" ");
	command.append("2");
	command.append(" ");
	union {
		double d;
		unsigned char bytes[8];
	} u;
	u.d = value;
	uint32_t unValue = (static_cast<uint32_t>(u.bytes[3]) << 24) |
		(static_cast<uint32_t>(u.bytes[2]) << 16) |
		(static_cast<uint32_t>(u.bytes[1]) << 8) |
		static_cast<uint32_t>(u.bytes[0]);
	command.append(std::to_string(unValue));
	command.append(" ");
	unValue = (static_cast<uint32_t>(u.bytes[7]) << 24) |
		(static_cast<uint32_t>(u.bytes[6]) << 16) |
		(static_cast<uint32_t>(u.bytes[5]) << 8) |
		static_cast<uint32_t>(u.bytes[4]);
	command.append(std::to_string(unValue));
	std::string recvData;
	if (sendAndReceiveMessage(command, recvData) && recvData == WRITE_SUCESS_RESPONSE_DATA)
	{
		res = true;
	}
	return res;
}
bool KeyencePlcSubSystemHelperPrivate::writeDoubles(const std::string address, const uint16_t length, const double *values)
{
	uint32_t sendLength = length * 2;
	bool res = false;
	std::string command = "WRS";
	command.append(" ");
	command.append(address);
	command.append(".D");
	command.append(" ");
	command.append(std::to_string(sendLength));
	command.append(" ");
	union {
		double d;
		unsigned char bytes[8];
	} u;
	for (size_t i = 0; i < length; i++)
	{
		u.d = values[i];
		uint32_t unValue = (static_cast<uint32_t>(u.bytes[3]) << 24) |
			(static_cast<uint32_t>(u.bytes[2]) << 16) |
			(static_cast<uint32_t>(u.bytes[1]) << 8) |
			static_cast<uint32_t>(u.bytes[0]);
		command.append(std::to_string(unValue));
		command.append(" ");
		unValue = (static_cast<uint32_t>(u.bytes[7]) << 24) |
			(static_cast<uint32_t>(u.bytes[6]) << 16) |
			(static_cast<uint32_t>(u.bytes[5]) << 8) |
			static_cast<uint32_t>(u.bytes[4]);
		command.append(std::to_string(unValue));
		command.append(" ");
	}
	command = command.substr(0, command.length() - 1);
	std::string recvData;
	if (sendAndReceiveMessage(command, recvData) && recvData == WRITE_SUCESS_RESPONSE_DATA)
	{
		res = true;
	}
	return res;
}

bool KeyencePlcSubSystemHelperPrivate::writeString(const std::string address, const std::string data)
{
	bool res = false;
	std::string command = "WRS";
	command.append(" ");
	command.append(address);
	command.append(".H");
	command.append(" ");
	int length = data.length();
	int sendLength = 0;
	if (length % 2 == 0)
	{
		sendLength = length / 2;
	}
	else
	{
		sendLength = length / 2 + 1;
	}
	command.append(std::to_string(sendLength));
	command.append(" ");
	int i = 1;
	for (const char c : data)
	{
		std::stringstream ss;
		ss << std::hex << std::uppercase << static_cast<int>(c);
		command.append(ss.str());
		if (i < length)
		{
			if (i % 2 == 0)
			{
				command.append(" ");
			}
			++i;
		}
	}
	//奇数长度结尾增加空字符
	if (i % 2 == 1)
	{
		command.append("00");
	}
	std::string recvData;
	if (sendAndReceiveMessage(command, recvData) && recvData == WRITE_SUCESS_RESPONSE_DATA)
	{
		res = true;
	}
	return res;
	return false;
}

std::vector<std::string> KeyencePlcSubSystemHelperPrivate::splitData(const std::string& data, char delimiter) {
	std::vector<std::string> tokens;
	std::string token;
	std::istringstream tokenStream(data);
	while (std::getline(tokenStream, token, delimiter)) {
		tokens.push_back(token);
	}
	return tokens;
}
//心跳信号,时间间隔1s，尝试5次
bool KeyencePlcSubSystemHelperPrivate::monitorHeartbeats()
{
	int count = 0;
	bool isConnected = false;
	while (count < 4)
	{
		readBit("MR9000", isConnected);
		if (isConnected)
		{
			return true;
		}
		else
		{
			Sleep(500);
		}
	}

	return false;
}




/**
* KeyencePlcSubSystemHelper
*/
KeyencePlcSubSystemHelper::KeyencePlcSubSystemHelper(const std::string& name)
	: d(new KeyencePlcSubSystemHelperPrivate(this, name)){

}


/**
* initialize
*/
bool KeyencePlcSubSystemHelper::enableProtocol(){
	return d->open();
}


/**
* unInitialize
*/
void KeyencePlcSubSystemHelper::disableProtocol(){
	d->close();
}

/**
*@brief  input count in module
*/
int KeyencePlcSubSystemHelper::helperInputCount()const
{
	return d->ioConfig.input_names.size();
}

/**
*@brief  output count in module
*/
int KeyencePlcSubSystemHelper::helperOutputCount()const
{
	return d->ioConfig.output_names.size();
}

/**
*@brief  get input address
*/
std::string KeyencePlcSubSystemHelper::getHelperInputAddress() const
{
	return d->ioConfig.input_address;
}

/**
*@brief  get input status
*/
std::string KeyencePlcSubSystemHelper::getHelperOutputAddress(const int index)const
{
	int count = d->ioConfig.output_addresses.size();
	if (index <count)
	{
		return d->ioConfig.output_addresses[index];
	}
	return "";
}


/**
*@brief  get input name
*/
std::string KeyencePlcSubSystemHelper::getHelperInputName(int index) const
{
	int count = d->ioConfig.input_names.size();
	if (index < count)
	{
		return d->ioConfig.input_names[index];
	}
	return "";
}

/**
*@brief  get input name
*/
std::string KeyencePlcSubSystemHelper::getHelperOutputName(int index) const
{
	int count = d->ioConfig.output_names.size();
	if (index < count)
	{
		return d->ioConfig.output_names[index];
	}
	return "";
}

