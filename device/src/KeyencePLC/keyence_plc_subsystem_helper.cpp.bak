/**
* KeyencePlcSubSystemHelperPrivate
*/
class KeyencePlcSubSystemHelperPrivate{
public:
	KeyencePlcSubSystemHelperPrivate(KeyencePlcSubSystemHelper* p, const std::string& name);
	//IO config
	struct IOConfig{
		std::vector<std::string> input_names;
		std::string input_address;
		std::vector<std::string> output_names;
		std::vector<std::string> output_addresses;
	} ioConfig;
	bool open()throw(KernelException);
	void close()throw(KernelException);

	bool setTimeout(const uint32_t milsecTime);
	void configure(const std::shared_ptr<KernelConfiguration> & config);
	std::shared_ptr<KeyencePlcSubSystemHelper::DefinedError> getErrorCode(const int code_type, const int code_id);

public:
	bool readBit(const std::string address, bool &value);
	bool readBits(const std::string address, const uint16_t length, bool *value);
	bool readShort(const std::string address, int16_t &value);
	bool readShorts(const std::string address, const uint16_t length, int16_t *value);
	bool readUnsignedShort(const std::string address, uint16_t &value);
	bool readUnsignedShorts(const std::string address, const uint16_t length, uint16_t *value);
	bool readInt(const std::string address, int32_t &value);
	bool readInts(const std::string address, const uint16_t length, int32_t *value);
	bool readUnsignedInt(const std::string address, uint32_t &value);
	bool readUnsignedInts(const std::string address, const uint16_t length, uint32_t *value);
	bool readFloat(const std::string address, float &value);
	bool readFloats(const std::string address, const uint16_t length, float *value);
	bool readDouble(const std::string address, double &value);
	bool readDoubles(const std::string address, const uint16_t length, double *value);
	bool readString(const std::string address, const uint16_t length, std::string &value);

	bool writeBit(const std::string address, const bool value);
	bool writeBits(const std::string address, const uint16_t length, const bool *values);
	bool writeShort(const std::string address, const int16_t value);
	bool writeShorts(const std::string address, const uint16_t length, const int16_t *values);
	bool writeUnsignedShort(const std::string address, const uint16_t value);
	bool writeUnsignedShorts(const std::string address, const uint16_t length, const uint16_t *values);
	bool writeInt(const std::string address, const int32_t value);
	bool writeInts(const std::string address, const uint16_t length, const int32_t *values);
	bool writeUnsignedInt(const std::string address, const uint32_t value);
	bool writeUnsignedInts(const std::string address, const uint16_t length, const uint32_t *values);
	bool writeFloat(const std::string address, const float value);
	bool writeFloats(const std::string address, const uint16_t length, const float *values);
	bool writeDouble(const std::string address, const double value);
	bool writeDoubles(const std::string address, const uint16_t length, const double *values);
	bool writeString(const std::string address, const std::string value);
public:
	uint16_t port = 8501;
	std::string ip_address = "192.168.0.10";
	uint32_t plc_timeout_milsec = 2000;
	std::shared_ptr<SOCKET> client;
	std::string name;

	std::string send_data_to_plc = "\r\n";
	const std::string WRITE_SUCESS_RESPONSE_DATA = "OK";
	std::mutex mtx;

	KeyencePlcSubSystemHelper* p;
	mutable std::mutex mutex;

	std::list<std::shared_ptr<KeyencePlcSubSystemHelper::DefinedError> > definedErrors;  //defined error from hardware

private:
	bool initialize();
	bool receiveMessage(std::string &data);
	bool sendMessage(const std::string data);
	bool sendAndReceiveMessage(const std::string sendData, std::string &recvData);
	std::vector<std::string> splitData(const std::string& data, char delimiter);

	bool monitorHeartbeats();
	
private:
	bool isConnected = false;
};


KeyencePlcSubSystemHelperPrivate::KeyencePlcSubSystemHelperPrivate(KeyencePlcSubSystemHelper*p, const std::string& name)
	:p(p)
	, name(name)
{

}


bool KeyencePlcSubSystemHelperPrivate::open(){
	isConnected = initialize();
	if (!isConnected)
	{
		throw KernelSysException(__FILE__, KernelSysException::KR_MODULE_COMMUNICATION_ERROR, Poco::format("无法连接到PLC服务器: %d", port));
	}
	return isConnected;
}


void KeyencePlcSubSystemHelperPrivate::close(){
	//if (isConnected)
	if (client)
	{
		if ((*client) != INVALID_SOCKET)
		{
			shutdown(*client, SD_BOTH);
			closesocket(*client);
			*client = INVALID_SOCKET;
		}
		WSACleanup();
	}
	isConnected = false;
	return;
}

bool KeyencePlcSubSystemHelperPrivate::initialize()
{
	WORD verision = MAKEWORD(2, 2);
	WSADATA lpData;
	int intEr = WSAStartup(verision, &lpData);
	if (intEr != 0)
	{
		logError(name.c_str(), "初始化Winsock失败！");
		return false;
	}
	client = std::make_shared<SOCKET>(socket(AF_INET, SOCK_STREAM, IPPROTO_TCP));
	if (*client == INVALID_SOCKET)
	{
		logError(name.c_str(), "创建socket失败！");
		WSACleanup();
		return false;
	}
	DWORD timeout = 1000; 
	setsockopt(*client, SOL_SOCKET, SO_RCVTIMEO, (const char*)&timeout, sizeof(timeout));
	// 设置服务器地址信息
	sockaddr_in serverAddr{};
	serverAddr.sin_family = AF_INET;
	serverAddr.sin_port = htons(port);
	if (inet_pton(AF_INET, ip_address.c_str(), &(serverAddr.sin_addr)) <= 0)
	{
		logError(name.c_str(), "IP地址验证失败.");
		closesocket(*client);
		WSACleanup();
		return false;
	}

	// 连接服务器
	if (connect(*client, reinterpret_cast<sockaddr*>(&serverAddr), sizeof(serverAddr)) < 0)
	{
		logError(name.c_str(), "连接服务器失败！");
		closesocket(*client);
		WSACleanup();
		return false;
	}
	isConnected = true;
	setTimeout(1000);
	bool isconnected = false;

	if (!sendMessage(""))
	{
		if (monitorHeartbeats())
		{
			return true;
		}
		else
		{
			logError(name.c_str(), "连接到PLC失败.");
			closesocket(*client);
			return false;
		}
	}
	std::string data = "";
	if (!receiveMessage(data))
	{
		if (monitorHeartbeats())
		{
			return true;
		}
		else
		{
			logError(name.c_str(), "接收PLC返回数据失败！");
			return false;
		}
	}
	return true;
}

void KeyencePlcSubSystemHelperPrivate::configure(const std::shared_ptr<KernelConfiguration> & config){

	port = std::stoi(config->getString("port", "8501"));
	ip_address = config->getString("ip", "192.168.1.100");
	plc_timeout_milsec = std::stoul(config->getString("plc_timeout", "1000"));

	//鼎能光电，错误文本加载
	if (config->has("ErrorTxt"))
	{
		std::string errFileName = config->getString("ErrorTxt", name + ".txt");
		// read file
		std::ifstream infile;
		std::string buffstr;
		infile.open(errFileName, std::ios::in);
		if (!infile.is_open()){
			throw KernelSysException(__FILE__, KernelSysException::KR_SYSTEM_WITHOUT_RESOURCE, Poco::format("错误文件定义: %s 打开失败.", errFileName));
		}
		// read line and line
		while (getline(infile, buffstr))
		{
			std::shared_ptr<KeyencePlcSubSystemHelper::DefinedError> errorObj(new KeyencePlcSubSystemHelper::DefinedError);
			Poco::StringTokenizer token(buffstr, ",", Poco::StringTokenizer::TOK_IGNORE_EMPTY);
			if (token.count() != 3){
				throw KernelSysException(__FILE__, KernelSysException::KR_SYSTEM_UNKNOWN_ERROR, Poco::format("错误文件定义: %s 格式错误.", errFileName));
			}

			errorObj->type = Poco::NumberParser::parse(token[0]);//type
			errorObj->code = Poco::NumberParser::parse(token[1]);//code
			errorObj->message = Poco::trim(token[2]);  //message
			errorObj->needReset = errorObj->message.back() == '*';  //need to reset
			if (errorObj->needReset) errorObj->message.pop_back();
			//add to defined errors
			definedErrors.push_back(errorObj);
		}
	}
	if (config->has("IO"))
	{
		//mapping input names
		do{
			Poco::StringTokenizer token(config->getString("IO.InPutNames", ""), ",", Poco::StringTokenizer::TOK_IGNORE_EMPTY);
			for (int i = 0; i < token.count(); i++){
				ioConfig.input_names.push_back(token[i]);
			}
		} while (false);
		ioConfig.input_address = config->getString("IO.InputAddress", "RM1000");
		//mapping output names
		do{
			Poco::StringTokenizer token(config->getString("IO.OutPutNames", ""), ",", Poco::StringTokenizer::TOK_IGNORE_EMPTY);
			for (int i = 0; i < token.count(); i++){
				ioConfig.output_names.push_back(token[i]);
			}
		} while (false);
		//mapping output addresses
		do{
			Poco::StringTokenizer token(config->getString("IO.OutputAddresses", ""), ",", Poco::StringTokenizer::TOK_IGNORE_EMPTY);
			for (int i = 0; i < token.count(); i++){
				ioConfig.output_addresses.push_back(token[i]);
			}
		} while (false);
	}
}

std::shared_ptr<KeyencePlcSubSystemHelper::DefinedError> KeyencePlcSubSystemHelperPrivate::getErrorCode(const int code_type, const int code_id)
{
	std::shared_ptr<KeyencePlcSubSystemHelper::DefinedError> res = std::make_shared<KeyencePlcSubSystemHelper::DefinedError>(KeyencePlcSubSystemHelper::DefinedError{ code_type, code_id, "", false });;
	for (const auto err : definedErrors)
	{
		if (code_type == err->type && code_id == err->code)
		{
			res = err;
			return res;
		}
	}
	res->type = code_type;
	res->code = code_id;
	res->message = "硬件中未找到错误代码定义";
	res->needReset = false;
	return res;
}



bool KeyencePlcSubSystemHelperPrivate::setTimeout(const uint32_t milsecTime)
{
	int ret = setsockopt(*client, SOL_SOCKET, SO_RCVTIMEO, (const char*)&milsecTime, sizeof(milsecTime));
	return ret != SOCKET_ERROR;
}

bool KeyencePlcSubSystemHelperPrivate::sendMessage(const std::string data)
{
	if (!isConnected)
	{
		return false;
	}
	send_data_to_plc = data + "\r\n";
	int err = send(*client, send_data_to_plc.c_str(), send_data_to_plc.size(), 0);
	if (err == SOCKET_ERROR || err == 0)
	{
		return false;
	}
	return true;
}

bool KeyencePlcSubSystemHelperPrivate::receiveMessage(std::string &data)
{
	data.clear();
	char receiveBuf[1024 * 50];
	int recvLen = recv(*client, receiveBuf, 1024 * 50, 0);
	if (recvLen == SOCKET_ERROR || recvLen == 0)
	{
		data = "error";
		return false;
	}
	data.append(receiveBuf, recvLen);
	size_t found = data.find("\r\n");
	if (found != std::string::npos)
	{
		data.erase(found, -2);
		return true;
	}
	data = "Timeout";
	return false;
}

bool KeyencePlcSubSystemHelperPrivate::sendAndReceiveMessage(const std::string sendData, std::string &recvData)
{
	bool res = false;
	mtx.lock();
	if (sendMessage(sendData) && receiveMessage(recvData) && (recvData.find("E") == std::string::npos))
	{
		res = true;
	}
	mtx.unlock();
	return res;
}

bool KeyencePlcSubSystemHelperPrivate::readBit(const std::string address, bool &value)
{
	std::string command = "RD";
	command.append(" ");
	command.append(address);
	std::string recvData;
	if (!sendAndReceiveMessage(command, recvData))
	{
		return false;
	}
	value = (std::stoi(recvData) == 1);
	return true;
}

bool KeyencePlcSubSystemHelperPrivate::readBits(const std::string address, const uint16_t length, bool *value)
{
	std::string command = "RDS";
	command.append(" ");
	command.append(address);
	command.append(" ");
	command.append(std::to_string(length));
	std::string recvData;
	if (!sendAndReceiveMessage(command, recvData))
	{
		return false;
	}
	auto vec_data = splitData(recvData, ' ');
	if (vec_data.size() != length)
	{
		return false;
	}
	for (size_t i = 0; i < length; i++)
	{
		value[i] = (std::stoi(vec_data[i]) == 1);
	}
	return true;
}

