bool KeyencePlcSubSystemHelperPrivate::readFloat(const std::string address, float &value)
{
	std::string command = "RD";
	command.append(" ");
	command.append(address);
	command.append(".D");
	std::string recvData;
	if (!sendAndReceiveMessage(command, recvData))
	{
		return false;
	}
	unsigned long unsigned_integer = std::stoul(recvData);
	//value = *(reinterpret_cast<float*>(&unsigned_integer));
	union {
		float f;
		unsigned char bytes[4];
	} u;
	for (int i = 0; i < 4; ++i) {
		u.bytes[i] = (unsigned_integer >> (i * 8)) & 0xFF;
	}
	value = u.f;
	return true;
}

bool KeyencePlcSubSystemHelperPrivate::readFloats(const std::string address, const uint16_t length, float *value)
{
	std::string command = "RDS";
	command.append(" ");
	command.append(address);
	command.append(".D");
	command.append(" ");
	command.append(std::to_string(length));
	std::string recvData;
	if (!sendAndReceiveMessage(command, recvData))
	{
		return false;
	}
	auto vec_data = splitData(recvData, ' ');
	if (vec_data.size() != length)
	{
		return false;
	}
	unsigned long unsigned_integer;
	union {
		float f;
		unsigned char bytes[4];
	} u;
	for (size_t i = 0; i < length; i++)
	{
		unsigned_integer = std::stoul(vec_data[i]);
		for (size_t j = 0; j < 4; j++)
		{
			u.bytes[j] = (unsigned_integer >> (j * 8)) & 0xFF;
		}
		value[i] = u.f;
		//unsigned long unsigned_integer = std::stoul(vec_data[i]);
		//value[i] = *(reinterpret_cast<float*>(&unsigned_integer));

	}

	return true;
}


bool KeyencePlcSubSystemHelperPrivate::readDouble(const std::string address, double &value)
{
	std::string command = "RDS";
	command.append(" ");
	command.append(address);
	command.append(".D");
	command.append(" ");
	command.append("2");
	std::string recvData;
	if (!sendAndReceiveMessage(command, recvData))
	{
		return false;
	}
	auto vec_data = splitData(recvData, ' ');
	if (vec_data.size() != 2)
	{
		return false;
	}
	unsigned long num1 = std::stoul(vec_data[0]);
	unsigned long num2 = std::stoul(vec_data[1]);
	union {
		double d;
		unsigned char bytes[8];
	} u;
	for (int i = 0; i < 4; ++i) {
		u.bytes[i] = (num1 >> (i * 8)) & 0xFF;
	}
	for (int i = 0; i < 4; ++i) {
		u.bytes[i + 4] = (num2 >> (i * 8)) & 0xFF;
	}
	value = u.d;

	return true;

}

bool KeyencePlcSubSystemHelperPrivate::readDoubles(const std::string address, const uint16_t length, double *value)
{
	int readLength = length * 2;
	std::string command = "RDS";
	command.append(" ");
	command.append(address);
	command.append(".D");
	command.append(" ");
	command.append(std::to_string(readLength));
	std::string recvData;
	if (!sendAndReceiveMessage(command, recvData))
	{
		return false;
	}
	auto vec_data = splitData(recvData, ' ');
	if (vec_data.size() != readLength)
	{
		return false;
	}
	unsigned long num1;
	unsigned long num2;
	union {
		double d;
		unsigned char bytes[8];
	} u;
	for (size_t j = 0; j < length; j++)
	{
		num1 = std::stoul(vec_data[2 * j]);
		num2 = std::stoul(vec_data[2 * j + 1]);

		for (int i = 0; i < 4; ++i) {
			u.bytes[i] = (num1 >> (i * 8)) & 0xFF;
		}
		for (int i = 0; i < 4; ++i) {
			u.bytes[i + 4] = (num2 >> (i * 8)) & 0xFF;
		}
		value[j] = u.d;
	}

	return true;
}

bool KeyencePlcSubSystemHelperPrivate::readString(const std::string address, const uint16_t length, std::string &value)
{
	value.clear();
	std::string command = "RDS";
	command.append(" ");
	command.append(address);
	command.append(".H");
	command.append(" ");
	command.append(std::to_string(length));
	std::string recvData;
	if (!sendAndReceiveMessage(command, recvData))
	{
		return false;
	}
	recvData.erase(std::remove(recvData.begin(), recvData.end(), 0x20), recvData.end());
	std::string resultTwoChar;
	for (size_t i = 0; i < recvData.length(); i += 2)
	{
		if (i + 1 < recvData.length())
		{
			resultTwoChar.clear();
			resultTwoChar += recvData[i];
			resultTwoChar += recvData[i + 1];
			int num = std::stoi(resultTwoChar, nullptr, 16); // 将十六进制字符串转换为十进制整数
			value += static_cast<char>(num);
		}

	}
	return true;
}

bool KeyencePlcSubSystemHelperPrivate::writeBit(const std::string address, const bool value)
{
	bool res = false;
	std::string command = "WR";
	command.append(" ");
	command.append(address);
	command.append(" ");
	std::string data = value ? "1" : "0";
	command.append(data);
	std::string recvData;
	if (sendAndReceiveMessage(command, recvData) && recvData == WRITE_SUCESS_RESPONSE_DATA)
	{
		res = true;
	}
	return res;
}
bool KeyencePlcSubSystemHelperPrivate::writeBits(const std::string address, const uint16_t length, const bool *values)
{
	bool res = false;
	std::string command = "WRS";
	command.append(" ");
	command.append(address);
	command.append(" ");
	command.append(std::to_string(length));
	command.append(" ");
	for (size_t i = 0; i < length; i++)
	{
		std::string data = values[i] ? "1" : "0";
		command.append(data);
		command.append(" ");
	}
	command = command.substr(0, command.length() - 1);
	std::string recvData;
	if (sendAndReceiveMessage(command, recvData) && recvData == WRITE_SUCESS_RESPONSE_DATA)
	{
		res = true;
	}
	delete values;
	values = nullptr;
	return res;
}
bool KeyencePlcSubSystemHelperPrivate::writeShort(const std::string address, const int16_t value)
{
	bool res = false;
	std::string command = "WR";
	command.append(" ");
	command.append(address);
	command.append(".S");
	command.append(" ");
	if (value >= 0)
	{
		command.append("+");
	}
	command.append(std::to_string(value));
	std::string recvData;
	if (sendAndReceiveMessage(command, recvData) && recvData == WRITE_SUCESS_RESPONSE_DATA)
	{
		res = true;
	}
	return res;
}
